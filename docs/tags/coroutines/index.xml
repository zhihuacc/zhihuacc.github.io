<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Coroutines on Zhua's Blogs</title><link>https://zhihuacc.github.io/tags/coroutines/</link><description>Recent content in Coroutines on Zhua's Blogs</description><generator>Hugo</generator><language>en-us</language><lastBuildDate>Fri, 17 Jul 2026 11:50:00 +0800</lastBuildDate><atom:link href="https://zhihuacc.github.io/tags/coroutines/index.xml" rel="self" type="application/rss+xml"/><item><title>Notes on C++ Coroutines - 1</title><link>https://zhihuacc.github.io/post/post-2-cpp-coroutines-1/</link><pubDate>Fri, 17 Jul 2026 11:50:00 +0800</pubDate><guid>https://zhihuacc.github.io/post/post-2-cpp-coroutines-1/</guid><description>&lt;h1 id="background"&gt;Background&lt;/h1&gt;
